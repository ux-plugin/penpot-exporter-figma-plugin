{
  "extends": "./tsconfig.base.json",
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "declaration": true,
    "declarationMap": true,
    "emitDeclarationOnly": true,
    "outDir": "./dist/plugin-dts",
    "rootDir": ".",
    "skipLibCheck": true,
    "strict": true,
    "noEmit": false,
    "typeRoots": ["./node_modules/@figma", "./node_modules/@types"]
  },
  "include": [
    "plugin-src/transformers/**/*",
    "plugin-src/translators/**/*",
    "plugin-src/utils/**/*",
    "plugin-src/libraries.ts",
    "plugin-src/processors/**/*",
    "common/**/*",
    "ui-src/types/**/*",
    "ui-src/lib/**/*"
  ]
}
